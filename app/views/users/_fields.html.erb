<%# locals: (f:, user:) %>

<%= errors_for user %>

<div class="row">
  <div class="col">
    <%= f.label :name, t(".name"), class: "form-label" %>
    <%= f.text_field :name, placeholder: t(".name_placeholder"), class: "form-control", required: true %>
  </div>
</div>

<% if Errbit::Config.user_has_username %>
  <div class="row">
    <div class="col">
      <%= f.label :username, t(".username"), class: "form-label" %>
      <%= f.text_field :username, class: "form-control", required: true %>
    </div>
  </div>
<% end %>

<div class="row">
  <div class="col">
    <%= f.label :email, t(".email"), class: "form-label" %>
    <%= f.text_field :email, placeholder: t(".email_placeholder"), class: "form-control", required: true %>
  </div>
</div>

<% if Errbit::Config.github_authentication %>
  <div class="row">
    <div class="col">
      <%= f.label :github_login, "#{Errbit::Config.github_site_title} login", class: "form-label" %>
      <%= f.text_field :github_login, class: "form-control" %>
    </div>
  </div>
<% end %>

<div class="row">
  <div class="col">
    <%= f.label :per_page, t(".entries"), class: "form-label" %>
    <%= f.select :per_page, [10, 20, 30, 50, 75, 100], {}, {class: "form-select"} %>
  </div>
</div>

<div class="row">
  <div class="col">
    <%= f.label :time_zone, t(".time_zone"), class: "form-label" %>
    <%= f.time_zone_select :time_zone, ActiveSupport::TimeZone.us_zones, {}, class: "form-select" %>
  </div>
</div>

<div class="row">
  <div class="col">
    <%= f.label :password, t(".password"), class: "form-label" %>
    <%= f.password_field :password, autocomplete: "off", class: "form-control", required: true %>
  </div>
</div>

<div class="row">
  <div class="col">
    <%= f.label :password_confirmation, t(".password_confirmation"), class: "form-label" %>
    <%= f.password_field :password_confirmation, class: "form-control", required: true %>
  </div>
</div>

<% if current_user.admin? %>
  <div class="row">
    <div class="col">
      <div class="form-check">
        <%= f.check_box :admin, class: "form-check-input" %>
        <%= f.label :admin, t(".admin"), class: "form-check-label" %>
      </div>
    </div>
  </div>
<% end %>

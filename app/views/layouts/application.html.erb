<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <title>
      <%= t(".title") %>
      &mdash;
      <%= yield(:page_title).present? ? yield(:page_title) : yield(:title) %>
    </title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <%= favicon_link_tag %>
    <%= csrf_meta_tag %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "bootstrap", "data-turbo-track": "reload", integrity: true %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload", integrity: true %>
    <%= javascript_include_tag :app %>
    <%= javascript_importmap_tags %>

    <%= yield :head %>
  </head>

  <body>
    <div class="container">
      <%= render "navbar" %>
    </div>

    <div class="container">
      <% if (breadcrumb = yield(:breadcrumb)).present? %>
        <%= breadcrumb %>
      <% end %>
    </div>

    <div id="alerts" class="container">
      <%= render "alerts" %>
    </div>

    <div class="container">
      <% if (action_bar = yield(:action_bar)).present? %>
        <%= action_bar %>
      <% end %>
    </div>

    <div class="container">
      <%= yield %>
    </div>

    <div class="container">
      <hr class="text-dark">

      <div class="row text-center text-muted">
        <span><%= t(".powered_html", link: link_to(t(".errbit"), "https://github.com/errbit/errbit", target: "_blank")) %></span>
      </div>

      <div class="row text-center text-muted">
        <span><%= Errbit::Version %></span>
      </div>
    </div>
  </body>
</html>

<%# locals: (problems:) %>

<% any_issue_links = problems.any? { |e| e.issue_link.present? && e.issue_link != "pending" } %>

<% on_page_that_can_include_multiple_different_apps = params[:controller] == "problems" %>

<%= form_tag do %>
  <table class="table table-bordered table-hover table-striped selectable"><!-- TODO: selectable? -->
    <thead>
      <tr>
        <th class="text-center"><%= check_box_tag "toggle_problems_checkboxes" %></th>
        <% if on_page_that_can_include_multiple_different_apps %>
          <th class="text-center"><%= link_for_sort t(".app") %></th>
        <% else %>
          <th class="text-center"><%= link_for_sort t(".env"), "environment" %></th>
        <% end %>
        <th class="text-center"><%= link_for_sort t(".what_and_where_html"), "message" %></th>
        <th class="text-center"><%= link_for_sort t(".latest"), "last_notice_at" %></th>
        <th  class="text-center"><%= link_for_sort t(".count") %></th>
        <% if any_issue_links %>
          <th class="text-center">Issue</th>
        <% end %>
        <th class="text-center"><%= t(".resolve") %></th>
      </tr>
    </thead>

    <tbody>
      <% ProblemDecorator.decorate_collection(problems).each do |problem| %>
        <tr class="<%= problem.resolved? ? "resolved" : "unresolved" %>"><!-- TODO: recheck -->
          <td class="">
            <div class="">
              <%= check_box_tag "problems[]", problem.id, selected_problems.member?(problem.id.to_s) %>
            </div>
          </td>

          <td class="">
            <div class="">
              <% if on_page_that_can_include_multiple_different_apps %>
                <%= link_to problem.app.name, app_path(problem.app), class: "", title: problem.app.name %>
                <span class="" title="<%= problem.environment %>">
                  <%= link_to problem.environment, problems_path(environment: problem.environment) %>
                </span>
              <% else %>
                <span class="" title="<%= problem.environment %>">
                  <%= link_to problem.environment, app_path(problem.app, environment: problem.environment) %>
                </span>
              <% end %>
            </div>
          </td>

          <td class="">
            <div class="">
              <%= link_to problem.link_text, app_problem_path(problem.app, problem), class: "", title: problem.message %>
              <em class="nowrap" title="<%= problem.where %>"><%= problem.where %></em>
              <% if problem.comments_count > 0 %>
                <% comment = problem.comments.last %>
                <br>
                <div class="">
                  <% if comment.user %>
                    <em class="">
                      <%= (Errbit::Config.user_has_username ? comment.user.username : comment.user.email).to_s %>:
                    </em>
                  <% end %>
                  <em><%= truncate(comment.body, length: 100, separator: " ") %></em>
                </div>
              <% end %>
            </div>
          </td>

          <td class="">
            <% value = "#{time_ago_in_words(problem.last_notice_at)} #{t("problems.table.ago")}" %>
            <div class="" title="<%= value %>"><%= value %></div>
          </td>

          <td class="text-center align-middle">
            <%= link_to problem.notices_count, app_problem_path(problem.app, problem) %>
          </td>

          <% if any_issue_links %>
            <td class="">
              <% if problem.app.issue_tracker_configured? && problem.issue_link.present? && problem.issue_link != "pending" %>
                <%= link_to image_tag("#{problem.issue_type}_goto.png"), problem.issue_link, target: "_blank", rel: "noopener noreferrer" %>
              <% end %>
            </td>
          <% end %>

          <td class="text-center align-middle">
            <% if problem.unresolved? %>
              <%= link_to resolve_app_problem_path(problem.app, problem),
                          title: "Resolve",
                          method: :patch,
                          data: {
                            confirm: problem_confirm("resolve_one")
                          },
                          class: "btn btn-primary" do %>
                <%= inline_svg_tag "icons/hand-thumbs-up-fill.svg" %>
              <% end %>
            <% else %>
              <%= inline_svg_tag "icons/arrow-repeat.svg" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if problems.none? %>
    <table>
      <tr>
        <td>
          <em>No errs here</em>
        </td>
      </tr>
    </table>
  <% end %>

  <%= paginate problems %>

  <div class="">
    <ul>
      <% [:merge, :unmerge, :resolve, :unresolve, :delete].each do |action| %>
        <li>
          <%= submit_tag t(".#{action}").capitalize,
                         id: "#{action}_problems",
                         class: "btn btn-primary",
                         data: {
                           action: polymorphic_path([action == :delete ? :destroy : action, :several_problems]),
                           confirm: problem_confirm(action)
                         } %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<% content_for :title, (all_errs ? t(".all_errors") : t(".unresolved_errors")) %>

<% content_for :head do %>
  <%= auto_discovery_link_tag :atom,
        problems_path(User.token_authentication_key => current_user.authentication_token, format: :atom),
        title: "Errbit notices at #{request.host}" %>
<% end %>

<% content_for :action_bar do %>
  <% if all_errs %>
    <%= link_to t(".hide_resolved"), problems_path(sort: params_sort, order: params_order), class: "btn btn-primary" %>
  <% else %>
    <%= link_to t(".show_resolved"), problems_path(all_errs: true, sort: params_sort, order: params_order), class: "btn btn-primary" %>
  <% end %>
<% end %>

<% content_for :breadcrumb do %>
  <div class="row">
    <div class="col">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to("Home", root_path) %></li>
          <li class="breadcrumb-item active" aria-current="page"><%= t(".errors") %></li>
        </ol>
      </nav>
    </div>
  </div>
<% end %>

<div class="row">
  <%= render "problems/search", all_errs: all_errs, app_id: nil, params_sort: params_sort, params_order: params_order %>
</div>

<div id="problems" class="row table-responsive">
  <%= render "problems/table", problems: problems %>
</div>
